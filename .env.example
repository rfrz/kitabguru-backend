# ===========================
# App
# ===========================
APP_NAME=KitabGuru Backend
APP_PORT=8001
API_PREFIX=/api/v1
CORS_ORIGINS=*

# ===========================
# Database (PostgreSQL)
# ===========================
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://kitabguru:secret@localhost:5432/kitabguru_db

# ===========================
# JWT Auth
# ===========================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ===========================
# Admin Seed (first run only)
# ===========================
ADMIN_EMAIL=admin@kitabguru.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword!

# ===========================
# Inference Service
# ===========================
INFERENCE_BASE_URL=http://localhost:8000
HF_TOKEN=

# ===========================
# IoT Authentication
# ===========================
IOT_API_KEY=your-iot-device-api-key-change-this

# ===========================
# Cloudflare Workers AI (Image Generation)
# ===========================
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
CF_IMAGE_MODEL=@cf/stabilityai/stable-diffusion-xl-base-1.0

# ===========================
# IoT Provider Toggles
# ===========================
# STT_PROVIDER options: 'groq' (cloud, low memory) or 'local' (faster-whisper, high memory)
STT_PROVIDER=local
# TTS_PROVIDER options: 'edge_tts' (cloud, high quality) or 'local' (piper, local generation)
TTS_PROVIDER=local

# ===========================
# Groq (STT - Speech-to-Text)
# ===========================
GROQ_API_KEY=your-groq-api-key
GROQ_WHISPER_MODEL=whisper-large-v3

# ===========================
# Edge-TTS (Text-to-Speech)
# ===========================
TTS_VOICE=id-ID-ArdiNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ===========================
# Media Storage
# ===========================
MEDIA_DIR=./media
MEDIA_BASE_URL=http://localhost:8001/media

# ===========================
# Video Pipeline (Islamic Aesthetic)
# ===========================
FFMPEG_PATH=ffmpeg
VIDEO_SLIDE_BG_COLOR=#0d1b2a
VIDEO_SLIDE_ACCENT_COLOR=#c9a84c
VIDEO_SLIDE_TEXT_COLOR=#f0ece2
VIDEO_SLIDE_SUB_COLOR=#8ab4b8
VIDEO_SLIDE_WIDTH=1280
VIDEO_SLIDE_HEIGHT=720

# ===========================
# Chat Context Window
# ===========================
# How many recent messages sent as context to Inference (0 = entire session)
CHAT_CONTEXT_WINDOW=20

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_MEDIA_PER_HOUR=10
RATE_LIMIT_API_PER_MINUTE=60

# ===========================
# Purge Scheduler (Soft Delete Cleanup)
# ===========================
PURGE_SOFT_DELETE_AFTER_DAYS=30
